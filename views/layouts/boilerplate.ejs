<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Jodhpur Mishthan Bhandar</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
</head>
<body>

  <!-- NAVBAR -->
  <nav class="navbar">
    <div class="nav-logo">
      <img src="/images/JMBlogo.png" alt="JMB Logo" class="logo-img"/>
      <span class="nav-brand">Jodhpur Mishthan Bhandar</span>
    </div>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/products">Our Sweets</a></li>
      <% if (isOwner) { %>
        <li><a href="/products/new" class="btn-nav">+ Add Sweet</a></li>
        <li><a href="/owner/dashboard" class="btn-nav">Dashboard</a></li>
        <li><a href="/owner/logout">Logout</a></li>
      <% } else { %>
        <li><a href="/owner/login" class="btn-nav">Owner Login</a></li>
      <% } %>
    </ul>
  </nav>

  <!-- FLASH MESSAGES -->
  <% if (success && success.length > 0) { %>
    <div class="flash flash-success">
      <span>&#10003; <%= success[0] %></span>
      <button onclick="this.parentElement.remove()">&#10005;</button>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash flash-error">
      <span>&#9888; <%= error[0] %></span>
      <button onclick="this.parentElement.remove()">&#10005;</button>
    </div>
  <% } %>

  <!-- PAGE CONTENT -->
  <main>
    <%- body %>
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <p class="footer-brand">Jodhpur Mishthan Bhandar</p>
      <p class="footer-tagline">Crafting sweetness since generations 🍬</p>
      <p class="footer-copy">&copy; 2025 JMB. All rights reserved.</p>
    </div>
  </footer>

</body>
</html>
