<% layout('layouts/boilerplate') %>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <p class="hero-sub">Welcome to</p>
    <h1 class="hero-title">Jodhpur Mishthan<br /><span>Bhandar</span></h1>
    <p class="hero-desc">
      Authentic Rajasthani sweets made with love, tradition & the finest
      ingredients — delivered fresh to your door.
    </p>
    <div class="hero-btns">
      <a href="/products" class="btn-primary">Explore Our Sweets</a>
      <a href="#about" class="btn-outline">Our Story</a>
    </div>
  </div>
  <div class="hero-decor">
    <div class="hero-circle c1"></div>
    <div class="hero-circle c2"></div>
    <div class="hero-circle c3"></div>
  </div>
</section>

<!-- FEATURES -->
<section class="features">
  <div class="feature-card">
    <div class="feat-icon">🌿</div>
    <h3>Pure Ingredients</h3>
    <p>
      No preservatives, no artificial colors — just pure ghee, milk & sugar.
    </p>
  </div>
  <div class="feature-card">
    <div class="feat-icon">🚚</div>
    <h3>Home Delivery</h3>
    <p>Fresh sweets delivered right to your doorstep across Jodhpur.</p>
  </div>
  <div class="feature-card">
    <div class="feat-icon">🏺</div>
    <h3>Traditional Recipes</h3>
    <p>Recipes passed down through generations, preserving authentic taste.</p>
  </div>
  <div class="feature-card">
    <div class="feat-icon">🎁</div>
    <h3>Gift Packaging</h3>
    <p>Beautifully packed boxes for festivals, weddings & celebrations.</p>
  </div>
</section>

<!-- ABOUT -->
<section class="about" id="about">
  <div class="about-text">
    <p class="section-label">Our Story</p>
    <h2>A Legacy of Sweetness</h2>
    <p>
      Jodhpur Mishthan Bhandar has been serving authentic Rajasthani sweets for
      generations. From the iconic Mawa Kachori to silky Ghewar, every sweet is
      crafted by hand using traditional methods and the finest local
      ingredients.
    </p>
    <p>
      Our mission is simple — bring the real taste of Jodhpur to your home, just
      as it has been enjoyed for centuries.
    </p>
    <a href="/products" class="btn-primary">See All Products</a>
  </div>
  <div class="about-image">
    <div class="about-img-box">
      <div class="about-img-decor"></div>
      <div class="about-img-inner">🍮</div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-banner">
  <h2>Craving Something Sweet?</h2>
  <p>Browse our full collection and place your order today.</p>
  <a href="/products" class="btn-primary btn-lg">Order Now</a>
</section>
