<% layout('layouts/boilerplate') %>

<section class="form-page">
  <div class="form-container">
    <p class="section-label">Owner Panel</p>
    <h2>Add New Sweet</h2>

    <form action="/products" method="POST" class="sweet-form">
      <div class="form-group">
        <label for="name">Sweet Name</label>
        <input type="text" id="name" name="name" placeholder="e.g. Motichoor Ladoo" required/>
      </div>

      <div class="form-group">
        <label for="price">Price (₹ per kg)</label>
        <input type="number" id="price" name="price" placeholder="e.g. 450" min="0" required/>
      </div>

      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          <option value="" disabled selected>Select a category</option>
          <option value="Ladoo">Ladoo</option>
          <option value="Barfi">Barfi</option>
          <option value="Halwa">Halwa</option>
          <option value="Mithai">Mithai</option>
          <option value="Dry Fruits">Dry Fruits</option>
          <option value="Seasonal">Seasonal</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div class="form-group">
        <label for="image">Image URL</label>
        <input type="text" id="image" name="image" placeholder="Paste image URL here"/>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="4" placeholder="Describe this sweet..."></textarea>
      </div>

      <div class="form-btns">
        <button type="submit" class="btn-primary">Add Sweet</button>
        <a href="/products" class="btn-outline">Cancel</a>
      </div>
    </form>
  </div>
</section>
